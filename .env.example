# Database
POSTGRES_USER=genemapr
POSTGRES_PASSWORD=genemapr_secret
POSTGRES_DB=genemapr
DATABASE_URL=postgresql+asyncpg://genemapr:genemapr_secret@postgres:5432/genemapr

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000

# External APIs
ENSEMBL_BASE_URL=https://rest.ensembl.org
CLINVAR_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# AI (stub for now)
LLM_API_KEY=stub

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO

# CORS - comma-separated list of allowed origins (use * for development)
CORS_ORIGINS=*
# Production example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
